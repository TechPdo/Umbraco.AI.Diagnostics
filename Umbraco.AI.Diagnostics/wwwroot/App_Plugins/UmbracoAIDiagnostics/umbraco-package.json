{
  "$schema": "../../umbraco-package-schema.json",
  "id": "Umbraco.AI.Diagnostics",
  "name": "Umbraco AI Diagnostics",
  "description": "AI-powered log diagnostics for Umbraco",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "sectionSidebarApp",
      "kind": "menuWithEntityActions",
      "alias": "UmbracoAIDiagnostics.SectionSidebarApp",
      "name": "Umbraco AIDiagnostics Sidebar",
      "element": "/App_Plugins/UmbracoAIDiagnostics/tree.js",
      "meta": {
        "label": "AIDiagnostics",
        "menu": "Umb.Menu.Settings"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "workspace",
      "alias": "UmbracoAIDiagnostics.Workspace",
      "name": "Umbraco AI Diagnostics Workspace",
      "element": "/App_Plugins/UmbracoAIDiagnostics/workspace.js",
      "meta": {
        "entityType": "umbraco-ai-diagnostics-item"
      }
    },
    {
      "type": "workspaceView",
      "alias": "UmbracoAIDiagnostics.WorkspaceView",
      "name": "Umbraco AI Diagnostics View",
      "element": "/App_Plugins/UmbracoAIDiagnostics/workspace-view.js",
      "weight": 200,
      "meta": {
        "label": "AI Diagnostics",
        "pathname": "umbracoai-diagnostics",
        "icon": "icon-wand"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.WorkspaceAlias",
          "match": "UmbracoAIDiagnostics.Workspace"
        }
      ]
    },
    {
      "type": "workspaceView",
      "alias": "UmbracoAIDiagnostics.TrendAnalysisView",
      "name": "Trend Analysis",
      "element": "/App_Plugins/UmbracoAIDiagnostics/trend-analysis-view.js",
      "weight": 150,
      "meta": {
        "label": "Trend Analysis",
        "pathname": "trend-analysis",
        "icon": "icon-chart"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.WorkspaceAlias",
          "match": "UmbracoAIDiagnostics.Workspace"
        }
      ]
    },
    {
      "type": "workspaceView",
      "alias": "UmbracoAIDiagnostics.VisualizationsView",
      "name": "Visualizations",
      "element": "/App_Plugins/UmbracoAIDiagnostics/visualizations-view.js",
      "weight": 140,
      "meta": {
        "label": "Visualizations",
        "pathname": "visualizations",
        "icon": "icon-pie-chart"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.WorkspaceAlias",
          "match": "UmbracoAIDiagnostics.Workspace"
        }
      ]
    },
    {
      "type": "entryPoint",
      "alias": "UmbracoAIDiagnostics.LogViewerSearchEnhancer",
      "name": "Log Viewer Search AI Analysis Enhancer",
      "js": "/App_Plugins/UmbracoAIDiagnostics/log-viewer-search-enhancer.js"
    },
    {
      "type": "modal",
      "alias": "UmbracoAIDiagnostics.Modal.LogAnalysis",
      "name": "Log Analysis Modal",
      "element": "/App_Plugins/UmbracoAIDiagnostics/log-analysis-modal.element.js"
    },
    {
      "type": "repository",
      "alias": "UmbracoAIDiagnostics.Repository",
      "name": "Umbraco AI Diagnostics Repository",
      "api": "/App_Plugins/UmbracoAIDiagnostics/repository.js"
    }
  ]
}